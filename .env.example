# Database Configuration
MONGODB_URI=mongodb://localhost:27017/sunce_erp
MONGODB_DB_NAME=sunce_erp

NODE_ENV=development
PORT=5000

# JWT Secrets
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# Frontend URL (used for CORS + password reset link)
FRONTEND_URL=http://localhost:3000

# Reverse proxy / load balancer
TRUST_PROXY=1

# Global rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5000

# Auth-specific rate limits
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=500
LOGIN_ATTEMPT_WINDOW_MS=900000
LOGIN_ATTEMPT_MAX=20

# SMTP / Email (required for password reset emails)
# Option A: host/port/auth
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Gmail note: use an "App Password" (enable 2‑Step Verification). If copied with spaces, remove spaces.
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Sunce ERP
#
# Option B: URL (takes precedence over host/port/auth)
# SMTP_URL=smtps://user:pass@smtp.gmail.com:465

# Dev-only helpers
# If SMTP is failing in development, you can temporarily return the reset link in API response.
# Never enable this in production.
FORGOT_PASSWORD_RETURN_LINK=false

# Cloudinary (required for pickup PDF/image uploads)
# Note: Never commit real secrets to git; keep them only in `.env`.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: default folder where pickup docs will be stored
CLOUDINARY_FOLDER=sunce_erp/pickup
# Optional (unsigned uploads): if you prefer using an upload preset instead of API_SECRET
# CLOUDINARY_UPLOAD_PRESET=your-upload-preset
