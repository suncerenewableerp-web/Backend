NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/sunce_erp
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
FRONTEND_URL=http://localhost:3000

# If deployed behind a reverse proxy / load balancer (Vercel/Render/Nginx/etc),
# enable trust proxy so req.ip + rate limiting works per-client.
TRUST_PROXY=1

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5000

# Auth-specific rate limits
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=500
LOGIN_ATTEMPT_WINDOW_MS=900000
LOGIN_ATTEMPT_MAX=20
